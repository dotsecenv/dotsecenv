#!/usr/bin/env bash
# terraform-credentials-dotsecenv — Terraform/OpenTofu credentials helper
# https://developer.hashicorp.com/terraform/internals/credentials-helpers
#
# Install: symlink or copy to ~/.terraform.d/plugins/
# Config:  credentials_helper "dotsecenv" { args = [] }
set -euo pipefail

# Terraform invokes: terraform-credentials-dotsecenv [args...] <verb> <hostname>
if [ $# -lt 2 ]; then
  echo "usage: terraform-credentials-dotsecenv <verb> <hostname>" >&2
  exit 1
fi

verb="${@: -2:1}"
host="${@: -1}"

case "$verb" in
  get)
    # Return stored JSON credentials object, or {} if none exist.
    dotsecenv secret get "$host" 2>/dev/null || echo "{}"
    ;;

  store)
    # Read the full credentials JSON object from stdin (drain until EOF per spec).
    input=$(cat)

    # Must be a JSON object containing a "token" key (pure bash, no external deps).
    [[ "$input" == "{"* ]] || { echo "error: expected JSON object" >&2; exit 1; }
    [[ "$input" =~ \"token\"[[:space:]]*: ]] || { echo "error: credentials object must contain a 'token' property" >&2; exit 1; }

    # Store the full JSON object as-is (preserves all properties per spec).
    # --json validates well-formed JSON.
    printf '%s' "$input" | dotsecenv secret store "$host" --json
    ;;

  forget)
    # --ignore-not-found: exit 0 if secret doesn't exist or was already deleted.
    # Infrastructure errors still propagate (stderr + non-zero) per spec.
    dotsecenv secret forget "$host" --ignore-not-found
    ;;

  *)
    echo "unsupported credentials helper verb: $verb" >&2
    exit 1
    ;;
esac
